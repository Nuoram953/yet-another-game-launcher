{
  "name": "yet-another-game-launcher",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri dev --config src-tauri/app/tauri.conf.json",
    "bindings": "cargo run -p app --bin export-bindings --manifest-path src-tauri/Cargo.toml",
    "test": "cd src-tauri && cargo test",
    "prepare": "husky",
    "migrate": "cd src-tauri && sqlx migrate run --source core/src/migrations"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lint-staged": "^16.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6",
    "@semantic-release/exec": "^7",
    "@semantic-release/git": "^10",
    "@semantic-release/github": "^12",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "semantic-release": "^25",
    "typescript": "~6.0.2",
    "vite": "^8.0.8"
  }
}
