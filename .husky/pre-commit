#!/bin/sh

set -e

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if printf '%s\n' "$staged_files" | grep -Eq '\.rs$'; then
  npx lint-staged
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(src-tauri/.*\.rs|src-tauri/core/src/migrations/)'; then
  if ! cargo sqlx --help >/dev/null 2>&1; then
    echo "cargo-sqlx is required to refresh src-tauri/.sqlx metadata for Rust or migration changes." >&2
    echo "Install it with: cargo install sqlx-cli --no-default-features --features rustls,sqlite" >&2
    exit 1
  fi

  pnpm run sqlx:prepare
  git add -A -- src-tauri/.sqlx
fi
